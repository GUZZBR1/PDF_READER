# Required shared password for private access.
# Use a long random value before exposing the app.
APP_PASSWORD=replace-with-a-strong-private-password

# Public browser URL for the backend API.
# For local Docker usage, keep localhost.
# For a VPS with separate ports, use http://YOUR_SERVER_IP:8000.
# For a domain deployment, use https://api.example.com or your chosen API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend login gate. Keep true for private deployments.
NEXT_PUBLIC_AUTH_ENABLED=true

# Comma-separated frontend origins allowed to call the backend.
# For a VPS with separate ports, add http://YOUR_SERVER_IP:3000.
# For HTTPS deployments, use the exact frontend origin, such as https://pdf.example.com.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
